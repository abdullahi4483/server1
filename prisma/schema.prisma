generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AccountType {
  SAVINGS
  CURRENT
  INVESTMENT
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PURCHASE
  FEE
  REFUND
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  PAID
}

enum CardType {
  VIRTUAL
  PHYSICAL
}

enum CardStatus {
  ACTIVE
  FROZEN
  EXPIRED
  REPLACED
}

enum TicketCategory {
  GENERAL
  ACCOUNT
  TRANSACTION
  WITHDRAWAL
  TECHNICAL
  FEEDBACK
}

enum TicketStatus {
  PENDING
  REPLIED
  RESOLVED
}

model User {
  id               String           @id @default(uuid())
  role             UserRole         @default(CLIENT)
  status           UserStatus       @default(ACTIVE)
  fullName         String
  email            String           @unique
  phone            String?
  passwordHash     String
  twoFactorEnabled Boolean          @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  refreshTokens    RefreshToken[]
  accounts         Account[]
  cards            Card[]
  transactions     Transaction[]
  withdrawals      Withdrawal[]
  supportThreads   SupportThread[]
  supportMessages  SupportMessage[]
  settings         UserSettings?
  auditLogs        AuditLog[]       @relation("audit_actor")
  reviewedItems    Withdrawal[]     @relation("withdrawal_reviewer")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  replacedBy  String?
  ipAddress   String?
  userAgent   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Account {
  id                  String        @id @default(uuid())
  userId              String
  type                AccountType
  status              AccountStatus @default(ACTIVE)
  accountNumberMasked String
  currency            String        @default("USD")
  availableBalance    Decimal       @db.Decimal(18, 2)
  ledgerBalance       Decimal       @db.Decimal(18, 2)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  withdrawals         Withdrawal[]
  cards               Card[]

  @@index([userId, type])
}

model Transaction {
  id          String               @id @default(uuid())
  accountId   String
  userId      String
  reference   String               @unique
  type        TransactionType
  direction   TransactionDirection
  amount      Decimal              @db.Decimal(18, 2)
  currency    String               @default("USD")
  status      TransactionStatus    @default(PENDING)
  description String
  metadataJson Json?
  postedAt    DateTime             @default(now())
  createdAt   DateTime             @default(now())
  account     Account              @relation(fields: [accountId], references: [id], onDelete: Restrict)
  user        User                 @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, postedAt])
  @@index([accountId, postedAt])
  @@index([type, status])
}

model Withdrawal {
  id              String            @id @default(uuid())
  userId          String
  accountId       String
  amount          Decimal           @db.Decimal(18, 2)
  currency        String            @default("USD")
  status          WithdrawalStatus  @default(PENDING)
  requestedAt     DateTime          @default(now())
  reviewedAt      DateTime?
  processedAt     DateTime?
  reviewedBy      String?
  rejectionReason String?
  riskFlagsJson   Json?
  user            User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  account         Account           @relation(fields: [accountId], references: [id], onDelete: Restrict)
  reviewer        User?             @relation("withdrawal_reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId, status, requestedAt])
}

model Card {
  id            String      @id @default(uuid())
  userId        String
  accountId     String
  brand         String
  cardType      CardType
  maskedPan     String
  last4         String
  expiryMonth   Int
  expiryYear    Int
  status        CardStatus  @default(ACTIVE)
  spendingLimit Decimal     @db.Decimal(18, 2)
  currentUsage  Decimal     @db.Decimal(18, 2) @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  account       Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
}

model SupportThread {
  id          String          @id @default(uuid())
  userId      String
  category    TicketCategory
  subject     String
  status      TicketStatus    @default(PENDING)
  priority    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages    SupportMessage[]

  @@index([userId, status, updatedAt])
}

model SupportMessage {
  id           String      @id @default(uuid())
  threadId     String
  senderUserId String
  senderRole   UserRole
  body         String
  createdAt    DateTime    @default(now())
  thread       SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       User        @relation(fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([threadId, createdAt])
}

model UserSettings {
  userId              String   @id
  emailNotifications  Boolean  @default(true)
  pushNotifications   Boolean  @default(true)
  language            String   @default("en")
  currency            String   @default("USD")
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformSettings {
  id                         String   @id @default("singleton")
  platformName               String   @default("Fintech")
  supportEmail               String
  adminEmail                 String
  withdrawalManualThreshold  Decimal  @db.Decimal(18, 2) @default(10000)
  autoApproveEnabled         Boolean  @default(false)
  autoApproveMaxAmount       Decimal  @db.Decimal(18, 2) @default(1000)
  sessionTimeoutMinutes      Int      @default(30)
  apiRateLimitPerHour        Int      @default(1000)
  updatedBy                  String?
  updatedAt                  DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  actorRole    UserRole?
  action       String
  resourceType String
  resourceId   String
  beforeJson   Json?
  afterJson    Json?
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("audit_actor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([resourceType, resourceId, createdAt])
}
